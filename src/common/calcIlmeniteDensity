// Calculation of a density of solid phase with given conversion
//
// Inputs:
//  INPUT_calcIlmeniteDensity_conversion   - current conversion state (0 - fully reduced, 1 - fully oxidized)
//
// Outputs:
//  OUTPUT_calcIlmeniteDensity  - density of solid phase
//
// Dependencies:
//  constant/physicalProperties.solids

OUTPUT_calcIlmeniteDensity #codeStream   // Output
{
    codeInclude
    #{
        #include "calcFunctions.H"
    #};

    codeOptions
    #{
        -I$(FOAM_CASE)/../../../src/common/
    #};

    code
    #{
        os << calcIlmeniteDensity(
            $<scalar>{${FOAM_CASE}/constant/physicalProperties.solids!Fe2O3/equationOfState/rho}, 
            $<scalar>{${FOAM_CASE}/constant/physicalProperties.solids!FeO/equationOfState/rho}, 
            $<scalar>{${FOAM_CASE}/constant/physicalProperties.solids!inerts/equationOfState/rho},
            $<scalar>{${FOAM_CASE}/constant/physicalProperties.solids!Ro},
            $<scalar>INPUT_calcIlmeniteDensity_conversion // Input
        );
    #};
};
