FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      fvModels;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //


HeterogeneousShrinkingCoreChemistryAbad
{
    type            HeterogeneousShrinkingCoreChemistry;
    libs            ("libHeterogeneousChemistry.so");
    // [-] oxygen carrying capacity
    Ro              ${${FOAM_CASE}/constant/physicalProperties.solids!Ro};
    gasPhaseName    gas;
    solidPhaseName  solids;
    inertsName      inerts;
    oxidizedName    Fe2O3;
    reducedName     FeO;

    // Note that average stoichiometric coefficients b are put inside 
    // pre-exponential factors and resulting factors are then downscaled to
    // to get correct total conversion times, see Table 1 in the article.
    
    reactions
    {
        Abad_H2
        {
            active      true;
            reaction    "Fe2O3 + H2 = 2 FeO + H2O";
            type        reactionRateControlled;

            rg      1.25e-6;    // [m] grain radius
            Ea      65.0e3;     // [J/mol] activation energy
            n       1;          // [-] reaction order

            // Recalculated values
            A       5.79881707e-2; // [m/s] chemical kinetic constant (k0)
            b       1;             // [mol/mol] legacy stoichiometric coeff

            // correctTASIF true;
            // k1 114;
            // k2 0.59;
        }

        Abad_CO
        {
            active      true;
            reaction    "Fe2O3 + CO = 2 FeO + CO2";
            type        reactionRateControlled;
            
            rg      1.25e-6;    // [m] grain radius
            Ea      80.7e3;     // [J/mol] activation energy
            n       0.8;        // [-] reaction order

            // Recalculated values
            A       9.35293076e-2; // [mol^(0.2)*m^(0.4)/s] chemical kinetic constant (k0)
            b       1;             // [mol/mol] legacy stoichiometric coeff

            // correctTASIF true;
            // k1 81;
            // k2 0.64;
        }

        Abad_CH4
        {
            active      true;
            reaction    "4 Fe2O3 + CH4 = 8 FeO + CO2 + 2 H2O";
            type        reactionRateControlled;
            
            rg      1.25e-6;    // [m] grain radius
            Ea      135.2e3;    // [J/mol] activation energy
            n       1;          // [-] reaction order

            // Recalculated values
            A       9.13426569; // [m/s] chemical kinetic constant (k0)
            b       4;          // [mol/mol] legacy stoichiometric coeff

            // correctTASIF true;
            // k1 28;
            // k2 0.6;
        }

        Abad_O2
        {
            active      true;
            reaction    "4 FeO + O2 = 2 Fe2O3";
            type        reactionRateControlled;

            rg      1.20e-6;    // [m] grain radius
            Ea      25.5e3;     // [J/mol] activation energy
            n       1;          // [-] reaction order

            // Recalculated values
            A       1.07108116e-3; // [m/s] chemical kinetic constant (k0)
            b       4;             // [mol/mol] legacy stoichiometric coeff

            // correctTASIF true; # estimate based on CH4 and CO, because there is no simulation data available
            // k1 100;
            // k2 0.62;
        }
    }
}


