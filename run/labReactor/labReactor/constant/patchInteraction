(
    wall
    {
        type rebound;
        e    0.9;
        mu   0.0;
    }
    inlet
    {
        type rebound;
        e    0.9;
        mu   0.0;
    }
    outlet
    {
        type escape;
        e    0.9;
        mu   0.0;
    }

);
