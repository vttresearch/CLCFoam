FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      phaseProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

phases (solids gas);

referencePhase gas;

solids
{
    type            multicomponentPhaseModel;
    residualAlpha   1e-8;
    alphaMax        0.62;
    diameterModel   constant;
    constantCoeffs
    {
        d           ${${FOAM_CASE}/caseParamsDict!particleD};
    }
}

gas
{
    type            multicomponentPhaseModel; // no reactions via chemistryModel
    diameterModel   none;
    residualAlpha   1e-8;
}

blending
{
    default
    {
        type            continuous;
        residualAlpha   1e-8;
        phase           gas;
    }
}

interfaceCompression {}
surfaceTension {}
aspectRatio {}


// Minimum allowable pressure
pMin            10000;


// ************************************************************************* //
