FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    
    "alpha.*"
    {
        // solver          PBiCGStab;
        // preconditioner  DIC;
        // implicitPhasePressure on;
		
        nCorrectors     1;
        nSubCycles      constant 8;
		
        tolerance       1e-10;
        relTol          0;
        minIter         1;
        
        dgdtLimit       1e-6;
    }

    p_rgh
    {
        solver          GAMG;
        smoother        DIC;
        tolerance       1e-10;
        relTol          0.01;
        minIter         1;
        maxIter         50;
    }

    p_rghFinal
    {
        $p_rgh;
        tolerance       1e-11;		
        relTol          0;
    }

    "U.*"
    {
        solver          PBiCGStab;
        preconditioner  DILU;

        tolerance       1e-07;
        relTol          0;
        minIter         1;
    }

    "(h|e).*"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-7;
        relTol          0;
        minIter         1;
    }

    "Theta.*"
    {
        solver          PBiCGStab;
        preconditioner  DILU;

        tolerance       1e-6;
        relTol          0;
        minIter         1;
    }

    "d.*"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;

        tolerance       1e-6;
        relTol          0;
        minIter         1;
    }

    "(k|epsilon).*"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-6;
        relTol          0;
        minIter         1;
    }

    "Yi.*"
    {
        solver          PBiCGStab;
        preconditioner  DILU;

        residualAlpha   1e-06;
        tolerance       1e-07;
        relTol          0;
        minIter         1;
    }

    "Ii.*|G.*"
    {
        solver                GAMG;
        smoother              symGaussSeidel;
        processorAgglomerator procFaces;
        nAgglomeratingCells   400;

        tolerance             1e-10;
        relTol                0.;
        minIter               1;
        maxIter               5;
    }

    yPsi
    {
        solver              GAMG;
        smoother            symGaussSeidel;

        tolerance           1e-12;
        relTol              0;
        maxIter             10;
    }
}

PIMPLE
{
    nOuterCorrectors         3;
    nCorrectors              1;
    nNonOrthogonalCorrectors 2;
    nEnergyCorrectors        1;

    faceMomentum        no;
    VmDdtCorrection     yes;
    dragCorrection      no;
    partialElimination  no;
}

relaxationFactors
{
    equations
    {
        ".*"                 1.0;
    }
}


