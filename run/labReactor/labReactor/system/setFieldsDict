defaultValues
{
    alpha.solids 0.0;
}

zones
{
    initialSolids
    {
        type        box;

        box         ( -0.012 -0.000001 -0.012 ) ( 0.012 0.040001 0.012 );

        values
        {
            alpha.solids #calc " $m / $ICvol / $rho ";
            alpha.gas    #calc " 1 - ( $m / $ICvol / $rho ) ";
