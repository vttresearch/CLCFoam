FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      alpha.solids.orig;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 1;

boundaryField
{
    inlet
    {
        type            fixedValue;
        // type            totalFlowRateAdvectiveDiffusive;
        // phi             phi.gas;
        // rho             rho.gas;
        // massFluxFraction 1;
        value           uniform 1;
    }
    outlet
    {
        type            fixedValue;
        value           uniform 1;
        // type            zeroGradient;
    }
    wall
    {
        type            zeroGradient;
    }
}


// ************************************************************************* //
