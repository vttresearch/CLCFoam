FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      phaseProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

phases (solids gas);

referencePhase gas;

solids
{
    type          multicomponentPhaseModel;
    residualAlpha 1e-10;
    alphaMax        0.62;
    diameterModel constant;
    constantCoeffs
    {
        d   ${${FOAM_CASE}/caseParamsDict!particleD};
        
    }
}

gas
{
    type            multicomponentPhaseModel;
    diameterModel   none;
    residualAlpha   1e-10;
}

blending
{
    default
    {
        type   continuous;
        phase  gas;
    }
}

interfaceCompression {}
surfaceTension {}
aspectRatio {}



