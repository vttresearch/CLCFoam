        type empty;
        faces
        (
            ( 0 1 5 4 ) // left
            ( 2 6 7 3 ) // right
            ( 0 4 6 2 ) // back
            ( 1 5 7 3 ) // front
            ( 0 2 3 1 ) // bottom
            ( 4 5 7 6 ) // top
