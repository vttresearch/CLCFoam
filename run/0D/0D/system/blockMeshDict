FoamFile
{
    version         2;
    format          ascii;
    class           dictionary;
    object          blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// 1 cell mesh

convertToMeters 1;

L ${${FOAM_CASE}/caseParamsDict!L};

X0 #calc " - $L / 2.0";
X1 #calc "   $L / 2.0";

Y0 $X0;
Y1 $X1;

Z0 $X0;
Z1 $X1;

vertices
(
    ( $X0 $Y0 $Z0 )
    ( $X0 $Y0 $Z1 )
    ( $X1 $Y0 $Z0 )
    ( $X1 $Y0 $Z1 )
    ( $X0 $Y1 $Z0 )
    ( $X0 $Y1 $Z1 )
    ( $X1 $Y1 $Z0 )
    ( $X1 $Y1 $Z1 )
);

blocks
(
    hex ( 0 2 6 4 1 3 7 5 ) ( 1 1 1 ) simpleGrading ( 1 1 1 )
);

edges
(
);

