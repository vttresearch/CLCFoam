FoamFile
{
    format      binary;
    class       volScalarField;
    location    "0";
    object      alpha.solids;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    "inlet_.*"
    {
        type            fixedValue;
        value           uniform 0;
    }
    "outlet.*"
    {
        type            fixedValue;
        value           uniform 0;
    }
    wall
    {
        type            zeroGradient;
    }
}


// ************************************************************************* //
