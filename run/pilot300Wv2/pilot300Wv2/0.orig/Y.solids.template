FoamFile
{
    version         2;
    format          ascii;
    class           volScalarField;
    location        "0";
    object          TO_BE_SET_BY_setICBC;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [ 0 0 0 0 0 0 0 ];

INPUT_getCorrespondingMassFraction_fieldName __FIELD_NAME__;
#include "$FOAM_CASE/../../../src/common/getCorrespondingMassFraction"
#remove INPUT_getCorrespondingMassFraction_fieldName
internalField  uniform $OUTPUT_getCorrespondingMassFraction;
#remove OUTPUT_getCorrespondingMassFraction

boundaryField
{
    "inlet_.*"
    {
        type            zeroGradient;
    }
    "outlet.*"
    {
        type            zeroGradient;
    }
    wall
    {
        type            zeroGradient;
    }
}


