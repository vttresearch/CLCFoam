FoamFile
{
    version     2.0;
    format      ascii;
    class       IOobject;
    location    "constant";
    object      patchInteraction;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //


patches
(
    // inlet_FR
    // inlet_AR
    // wall
    // inlet_SL
    // inlet_DC2
    // outlet_AR
    // outlet_FR
    "wall.*"
    {
        type rebound;
        e    0.9;
        mu   0.0;
    }
    "inlet.*"
    {
        type rebound;
        e    0.9;
        mu   0.0;
    }
    "outlet.*"
    {
        type escape;
        e    0.9;
        mu   0.0;
    }

);
