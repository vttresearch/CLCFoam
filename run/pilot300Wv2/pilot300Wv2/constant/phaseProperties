FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      phaseProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

phases (solids gas);

referencePhase gas;

solids
{
    type          multicomponentPhaseModel;

    residualAlpha 1e-5;
    alphaMax 0.62;
    diameterModel constant;

    constantCoeffs
    {
        d               ${${FOAM_CASE}/caseParamsDict!particleD}; // Fresh ilmenite [Moldenhauer's thesis]

    }
}

gas
{
    type            reactingPhaseModel;

    diameterModel constant;
    constantCoeffs
    {
        d               1;
    }

    residualAlpha 1e-5;
}

blending
{
    default
    {
        type   continuous;
        residualAlpha   1e-6;
        phase  gas;
    }
}

interfaceCompression
{}

surfaceTension
{}

aspectRatio
{}

// Minimum allowable pressure
pMin            10000;


