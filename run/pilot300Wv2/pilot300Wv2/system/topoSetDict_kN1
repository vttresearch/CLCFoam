FoamFile
{
    format      ascii;
    class       dictionary;
    object      topoSetDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

configControlVolume {
    includeCut false;
    useSurfaceOrientation true;
    includeInside   true;
    includeOutside  false;
    nearDistance    2e-5;
    curvature       -1.;
}

actions
(

    // Fluidization sources
    {
        action  new;
        type    cellSet;
        name    inlet_DC;
        source  cylinderToCell;
        point1  (-0.0065 0.05 0.025);
        point2  (-0.0065 0.05 0);
        radius  0.0035;
    }

    // Solids loading
    {
        action  new;
        type    cellZoneSet;
        name    solids_loading;
        source  boxToCell;
        box     (-0.1 -0.1 -0.1) 
                ( 0.1  0.2  0.1);
    }

    // Control surfaces
    {
        action  new;
        type    faceSet;
        name    controlSurface_SL_AR;
        source  boxToFace;
        box     (-0.00751  0.0010 -0.00001) 
                (-0.00149  0.0014  0.02501);
    }
    {
        name    controlSurface_SL_AR;
        type    faceZoneSet;
        action  new;
        source  setAndNormalToFaceZone;
        faceSet controlSurface_SL_AR;
        normal  (0 1 0);
    }
    {
        action  new;
        type    faceSet;
        name    controlSurface_SL_FR;
        source  boxToFace;
        box     (-0.00001  0.00102 -0.00001) 
                ( 0.00451  0.00137  0.02501);
    }
    {
        name    controlSurface_SL_FR;
        type    faceZoneSet;
        action  new;
        source  setAndNormalToFaceZone;
        faceSet controlSurface_SL_FR;
        normal  (0 1 0);
    }
    {
        action  new;
        type    faceSet;
        name    controlSurface_DC_AR;
        source  boxToFace;
        box     (-0.019  0.182 0.015) 
                (-0.001  0.184 0.0251);
    }
    {
        action  add;
        type    faceSet;
        name    controlSurface_DC_AR;
        source  boxToFace;
        box     (-0.019  0.182 0.014) 
                (-0.001  0.183 0.015);
    }
    {
        name    controlSurface_DC_AR;
        type    faceZoneSet;
        action  new;
        source  setAndNormalToFaceZone;
        faceSet controlSurface_DC_AR;
        normal  (0 1 0);
    }
    {
        action  new;
        type    faceSet;
        name    controlSurface_DC_FR;
        source  boxToFace;
        box     (-0.0002 0.11999 -0.00001) 
                ( 0.0005 0.18501  0.01126);
    }
    {
        name    controlSurface_DC_FR;
        type    faceZoneSet;
        action  new;
        source  setAndNormalToFaceZone;
        faceSet controlSurface_DC_FR;
        normal  (1 0 0);
    }

    // Control volumes
    {
        name    controlVolume_SL;
        type    cellSet;
        action  new;
        source  surfaceToCell;
        sourceInfo
        {
            file    "constant/triSurface/controlVolume_SL.stl";
            outsidePoints ((0.02 0.4 0.01));
            $configControlVolume
        }
    }
    {
        name    controlVolume_DC;
        type    cellSet;
        action  new;
        source  surfaceToCell;
        sourceInfo
        {
            file    "constant/triSurface/controlVolume_DC.stl";
            outsidePoints ((0.02 0.4 0.01));
            $configControlVolume
        }
    }
    {
        name    controlVolume_AR;
        type    cellSet;
        action  new;
        source  surfaceToCell;
        sourceInfo
        {
            file    "constant/triSurface/controlVolume_AR.stl";
            outsidePoints ((0.02 0.4 0.01));
            $configControlVolume
        }
    }
    {
        name    controlVolume_FR;
        type    cellSet;
        action  new;
        source  surfaceToCell;
        sourceInfo
        {
            file    "constant/triSurface/controlVolume_FR.stl";
            outsidePoints ((-0.02 0.4 0.01));
            $configControlVolume
        }
    }
);

