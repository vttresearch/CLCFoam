// Averaged phase densities [-]
#includeFunc fieldAverage(fields=(
    multiply(alpha.gas,rho.gas)
    multiply(alpha.solids,rho.solids)
    ))
favreVelocityAverage
{
    type            fieldAverage;
    libs            ("libfieldFunctionObjects.so");
    writeControl    writeTime;
    fields
    (
        alphaRhoU.gas
        {
            mean    yes;
        }
        alphaRhoU.solids
        {
            mean    yes;
        }
    );
}
favreVelocityGas
{
    type            divide;
    libs            ("libfieldFunctionObjects.so");
    fields          (alphaRhoU.gasMean multiply(alpha.gas,rho.gas)Mean);
    result          U.gasMean_favre;
    executeControl  writeTime;
    writeControl    writeTime;
}
favreVelocitySolids
{
    type            divide;
    libs            ("libfieldFunctionObjects.so");
    fields          (alphaRhoU.solidsMean multiply(alpha.solids,rho.solids)Mean);
    result          U.solidsMean_favre;
    executeControl  writeTime;
    writeControl    writeTime;
}
