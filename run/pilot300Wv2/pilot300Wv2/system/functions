// Cell phase density [kg/m^3]
#includeFunc multiply(executeControl=timeStep,executeInterval=1,writeControl=none,fields=(alpha.gas rho.gas))
#includeFunc multiply(executeControl=timeStep,executeInterval=1,writeControl=none,fields=(alpha.solids rho.solids))
alphaRhoUGas
{
    type            multiply;
    libs            ("libfieldFunctionObjects.so");
    fields          (alpha.gas rho.gas U.gas);
    result          alphaRhoU.gas;
    executeControl  timeStep;
    executeInterval 1;
    writeControl    none;
}
alphaRhoUSolids
{
    type            multiply;
    libs            ("libfieldFunctionObjects.so");
    fields          (alpha.solids rho.solids U.solids);
    result          alphaRhoU.solids;
    executeControl  timeStep;
    executeInterval 1;
    writeControl    none;
}
