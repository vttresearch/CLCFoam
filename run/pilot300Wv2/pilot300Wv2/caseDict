// Reads specie list and densities from physicalProperties.solids
// Reads specie list from physicalProperties.gas

// ------------=== Parameters to modify ===-------------

#include "$FOAM_CASE/caseParamsDict"

// ------------=== Derived parameters ===-------------

// List of mass fractions for gaseous species at inlets
INPUT_gasMassFractionsDictToList $composition_FR;
    #include "$FOAM_CASE/../../../src/common/gasMassFractionsDictToList"
        Y_gas_FR $OUTPUT_gasMassFractionsDictToList; 
    #remove OUTPUT_gasMassFractionsDictToList
#remove INPUT_gasMassFractionsDictToList

INPUT_gasMassFractionsDictToList $composition_AR;
    #include "$FOAM_CASE/../../../src/common/gasMassFractionsDictToList"
        Y_gas_AR $OUTPUT_gasMassFractionsDictToList;
    #remove OUTPUT_gasMassFractionsDictToList
#remove INPUT_gasMassFractionsDictToList

INPUT_gasMassFractionsDictToList $composition_SL;
    #include "$FOAM_CASE/../../../src/common/gasMassFractionsDictToList"
        Y_gas_SL $OUTPUT_gasMassFractionsDictToList;
    #remove OUTPUT_gasMassFractionsDictToList
#remove INPUT_gasMassFractionsDictToList

